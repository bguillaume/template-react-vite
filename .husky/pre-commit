#!/bin/sh
husky_sh="$(dirname "$0")/_/husky.sh"
if [ -f "$husky_sh" ]; then
  . "$husky_sh"
fi

# Check branch name (must match pr-base-check.yml workflow's conventional prefix list)
local_branch="$(git rev-parse --abbrev-ref HEAD)"

# Skip branch-name enforcement during detached HEAD workflows
if [ "$local_branch" != "HEAD" ]; then
  case "$local_branch" in
    main|master|develop)
      ;;
    feat/*|fix/*|chore/*|docs/*|refactor/*|test/*|ci/*|build/*|perf/*|style/*|task/*|hotfix/*|release/*|dependabot/*|renovate/*|analysis/*)
      branch_suffix="${local_branch#*/}"
      if ! printf '%s\n' "$branch_suffix" | grep -Eq '^[A-Za-z0-9_/.-]+$'; then
        echo "❌ Error: Branch name '$local_branch' contains invalid characters."
        echo "   Use only letters, numbers, slashes, hyphens, underscores, and dots after the prefix."
        exit 1
      fi
      ;;
    *)
      echo "❌ Error: Branch name '$local_branch' does not follow conventional prefixes."
      echo "   Allowed: feat/, fix/, chore/, docs/, refactor/, test/, ci/, build/,"
      echo "            perf/, style/, task/, hotfix/, release/, dependabot/, renovate/, analysis/"
      exit 1
      ;;
  esac
fi

# Run lint-staged and fail the commit if it cannot be executed
if ! npx --no-install lint-staged; then
  echo "❌ Error: Failed to run lint-staged. Ensure dependencies are installed and try again."
  exit 1
fi


# Gitleaks — auto-installed via scripts/install-gitleaks.cjs (skipped in CI)
pnpm exec gitleaks protect --staged --redact --no-banner --config .gitleaks.toml

#!/bin/sh
husky_sh="$(dirname "$0")/_/husky.sh"
if [ -f "$husky_sh" ]; then
  . "$husky_sh"
fi

# Check branch name
local_branch="$(git rev-parse --abbrev-ref HEAD)"

# Skip branch-name enforcement during detached HEAD workflows
if [ "$local_branch" != "HEAD" ]; then
  case "$local_branch" in
    main|master|develop)
      ;;
    feature/*|bugfix/*|hotfix/*|release/*|chore/*|feat/*|fix/*|docs/*|refactor/*|test/*)
      branch_suffix="${local_branch#*/}"
      if ! printf '%s\n' "$branch_suffix" | grep -Eq '^[A-Za-z0-9_-]+$'; then
        echo "❌ Error: Branch name '$local_branch' contains invalid characters."
        echo "   Use only letters, numbers, hyphens, and underscores after the slash."
        exit 1
      fi
      ;;
    *)
      echo "❌ Error: Branch name '$local_branch' does not follow Git Flow conventions."
      echo "   Must start with: feature/, bugfix/, hotfix/, release/, chore/, feat/, fix/, docs/, refactor/, test/"
      exit 1
      ;;
  esac
fi

# Run lint-staged and fail the commit if it cannot be executed
if ! npx --no -- lint-staged; then
  echo "❌ Error: Failed to run lint-staged. Ensure dependencies are installed and try again."
  exit 1
fi
